# Copy this file to .env and fill in your local values.

# Docker Postgres settings.
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Nginx public ports.
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Local non-Docker connection string. Docker Compose overrides DATABASE_URL
# inside the API container using the Postgres settings above.
DATABASE_URL=

# Required only for the LLM retrieval planner. If this is blank or missing,
# the app uses the deterministic fallback planner.
OPENAI_API_KEY=

# Optional. Change this if you want to test another OpenAI model.
OPENAI_MODEL=gpt-5.5
